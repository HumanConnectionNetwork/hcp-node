# Telegram Bot token provided by BotFather
TELEGRAM_BOT_TOKEN=

# Base URL of the HCP Node
# The current MVP can operate with local JSON storage,
# but this variable is reserved for Node API communication.
HCP_NODE_URL=http://localhost:8000

# Default user interface language
DEFAULT_LANGUAGE=es

# HTTP timeout for HCP Node requests, in seconds
REQUEST_TIMEOUT=10

# Runtime environment: development or production
ENVIRONMENT=development
